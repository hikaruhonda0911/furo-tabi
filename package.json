{
  "name": "furo-tabi",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check": "biome check --write app lib README.md biome.json package.json",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > types/supabase.ts && pnpm biome check --write types/supabase.ts",
    "prepare": "husky",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "dev:vinext": "vite dev --port 3001",
    "build:vinext": "vite build"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@supabase/supabase-js": "^2.97.0",
    "date-fns": "^2.30.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "nuqs": "^2.8.8",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@cloudflare/vite-plugin": "^1.29.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitejs/plugin-rsc": "^0.5.21",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "react-server-dom-webpack": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5",
    "vinext": "^0.0.31",
    "vite": "^8.0.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.75.0"
  },
  "type": "module"
}
