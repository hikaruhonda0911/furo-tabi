# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Rakuten Travel API (server-side only)
RAKUTEN_APP_ID=your-rakuten-app-id
RAKUTEN_ACCESS_KEY=your-rakuten-access-key

# Site URL (used for sitemap, OGP, etc.)
# NEXT_PUBLIC_SITE_URL=https://example.com

# Google Tag Manager (GTM)
# GTMコンテナID（例: GTM-XXXXXXX）。設定するとGTM経由でGA4等を管理できる。
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Analytics 4 (GA4) — GTM未使用時のフォールバック
# GA4測定ID（例: G-XXXXXXXXXX）。GTM_IDが設定されている場合は不要。
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Google Search Console 検証メタタグ
# GSCのHTML タグ検証で発行されるcontent値を設定する。
# NEXT_PUBLIC_GSC_VERIFICATION=your-gsc-verification-code
